# API 認証用の共有シークレット (Bearer Token)
API_AUTH_SECRET=replace-with-a-long-random-string

# LLM プロバイダの API キー (利用するものだけ設定)
LLM_API_KEY_GROQ=
LLM_API_KEY_TOGETHER=
LLM_API_KEY_OPENAI=
LLM_API_KEY_ANTHROPIC=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Google Cloud (ローカル開発では未設定でも可)
GOOGLE_CLOUD_PROJECT=
